# Local Development Profile Example
# Copy this file to application-local.properties and modify as needed
# This profile is used when running the app locally

# Command Database (Write Side) - Local
spring.datasource.command.url=jdbc:postgresql://localhost:5432/crescendo_command
spring.datasource.command.username=your_username
spring.datasource.command.password=your_password
spring.datasource.command.driver-class-name=org.postgresql.Driver

# Query Database (Read Side) - Local
spring.datasource.query.url=jdbc:postgresql://localhost:5432/crescendo_query
spring.datasource.query.username=your_username
spring.datasource.query.password=your_password
spring.datasource.query.driver-class-name=org.postgresql.Driver

# Local Development Settings
spring.jpa.show-sql=false
logging.level.org.springframework.web=DEBUG

# Required for encrypting connection credentials at rest (AES-256 Base64 key)
credentials.crypto.key=REPLACE_WITH_BASE64_32_BYTE_KEY

# Public app URLs used for OAuth callbacks and native no-code public links
app.frontend-url=http://localhost:3000
app.backend-url=http://localhost:8080
app.form.base-url=${app.backend-url}/public/forms
app.approval.base-url=${app.backend-url}/public/approvals

# OAuth2 client registrations (for direct OAuth login/connect flows)
# The Google client is reused for Google Sheets, Drive, Calendar, and Forms if those scopes are enabled.
spring.security.oauth2.client.registration.google.client-id=REPLACE_ME
spring.security.oauth2.client.registration.google.client-secret=REPLACE_ME
spring.security.oauth2.client.registration.github.client-id=REPLACE_ME
spring.security.oauth2.client.registration.github.client-secret=REPLACE_ME

# Integration OAuth providers use the provider-key structure below:
# crescendo.integrations.oauth.providers.{provider-key}.client-id=...
# crescendo.integrations.oauth.providers.{provider-key}.client-secret=...
# crescendo.integrations.oauth.providers.{provider-key}.authorize-url=...
# crescendo.integrations.oauth.providers.{provider-key}.token-url=...
# crescendo.integrations.oauth.providers.{provider-key}.scopes=...
#
# Use application.properties.example as the canonical source for the full provider matrix,
# including Gmail, Google Sheets, Google Drive, Google Calendar, Google Forms,
# Google Tasks, Google Slides, Google Docs, Microsoft Excel, Microsoft Outlook,
# Microsoft Teams, GitHub, Discord, Notion, Linear, Airtable,
# X, Reddit, Spotify, Twitch, Strava, Figma, LinkedIn, GitLab, and Shopify.

# SMTP relay for crescendo-email action
crescendo.email.smtp.host=REPLACE_ME
crescendo.email.smtp.port=587
crescendo.email.smtp.username=REPLACE_ME
crescendo.email.smtp.password=REPLACE_ME

# Optional provider keys for controlled internal connections
gemini.api.key=REPLACE_ME_IF_USED
sarvam.api.key=REPLACE_ME_IF_USED

# Razorpay and PayPal are user-owned connection credentials by default.
# Configure keyId/keySecret or clientId/clientSecret in the user's Connection UI.

# Optional OAuth provider rows for newly added apps are listed in application.properties.example.
# Token-based connections work immediately for Trello, Asana, HubSpot, Dropbox, etc.
