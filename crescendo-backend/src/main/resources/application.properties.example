crescendo.integrations.oauth.providers.zendesk.client-id=REPLACE_ME
crescendo.integrations.oauth.providers.zendesk.client-secret=REPLACE_ME
crescendo.integrations.oauth.providers.zendesk.authorize-url=https://{subdomain}.zendesk.com/oauth/authorizations/new
crescendo.integrations.oauth.providers.zendesk.token-url=https://{subdomain}.zendesk.com/oauth/tokens
crescendo.integrations.oauth.providers.zendesk.scopes=read write

