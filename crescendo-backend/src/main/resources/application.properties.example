# Main Application Properties Example
# Copy this file to application.properties and modify as needed

spring.application.name=crescendo

# Default active profile (can be overridden)
spring.profiles.active=local

# Common JPA Configuration
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Credentials Encryption (AES-256)
credentials.crypto.key=REPLACE_WITH_BASE64_32_BYTE_KEY

# Public app URLs
app.frontend-url=https://app.crescendo.run
app.backend-url=https://api.crescendo.run
app.form.base-url=${app.backend-url}/public/forms
app.approval.base-url=${app.backend-url}/public/approvals

# =====================================================================
# 1. PLATFORM MANAGED API KEYS (AuthType.NONE)
# These are public/free-tier APIs that the platform owner pays for or
# provisions so users don't have to provide their own keys.
# =====================================================================

# NASA Open APIs (Free, https://api.nasa.gov/)
crescendo.platform.nasa-api-key=REPLACE_ME

# OpenWeatherMap API (Free tier: 1M calls/month, https://openweathermap.org/api)
crescendo.platform.weather-api-key=REPLACE_ME

# Giphy Developers (Free tier, https://developers.giphy.com/)
crescendo.platform.giphy-api-key=REPLACE_ME

# Brandfetch Logo API (Free tier: 100 req/mo, https://brandfetch.com/developers)
crescendo.platform.brandfetch-api-key=REPLACE_ME

# CoinGecko Crypto API (Free tier: 10k req/mo, https://www.coingecko.com/en/api)
crescendo.platform.coingecko-api-key=REPLACE_ME

# Marketstack EOD Data (Free tier: 100 req/mo, https://marketstack.com/)
crescendo.platform.marketstack-api-key=REPLACE_ME

# Job Search APIs
# SerpAPI (Google Jobs, 100 free/mo: https://serpapi.com)
crescendo.jobsearch.serpapi-key=REPLACE_ME
# Adzuna (Free tier: https://developer.adzuna.com)
crescendo.jobsearch.adzuna-app-id=REPLACE_ME
crescendo.jobsearch.adzuna-api-key=REPLACE_ME
# Jooble (Free: https://jooble.org/api/about)
crescendo.jobsearch.jooble-api-key=REPLACE_ME

# =====================================================================
# 2. OAUTH2 PROVIDERS (AuthType.OAUTH2)
# These apps act on behalf of the user, requiring the user to
# connect their personal accounts via OAuth.
# =====================================================================

# Gmail
crescendo.integrations.oauth.providers.gmail.client-id=REPLACE_ME
crescendo.integrations.oauth.providers.gmail.client-secret=REPLACE_ME
crescendo.integrations.oauth.providers.gmail.authorize-url=https://accounts.google.com/o/oauth2/v2/auth
crescendo.integrations.oauth.providers.gmail.token-url=https://oauth2.googleapis.com/token
crescendo.integrations.oauth.providers.gmail.scopes=https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.labels https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile

# Google Sheets
crescendo.integrations.oauth.providers.google-sheets.client-id=REPLACE_ME
crescendo.integrations.oauth.providers.google-sheets.client-secret=REPLACE_ME
crescendo.integrations.oauth.providers.google-sheets.authorize-url=https://accounts.google.com/o/oauth2/v2/auth
crescendo.integrations.oauth.providers.google-sheets.token-url=https://oauth2.googleapis.com/token
crescendo.integrations.oauth.providers.google-sheets.scopes=https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile

