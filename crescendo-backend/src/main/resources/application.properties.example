crescendo.integrations.oauth.providers.mailchimp.authorize-url=https://login.mailchimp.com/oauth2/authorize
crescendo.integrations.oauth.providers.mailchimp.token-url=https://login.mailchimp.com/oauth2/token
crescendo.integrations.oauth.providers.mailchimp.scopes=

