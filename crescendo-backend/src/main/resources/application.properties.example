# SMTP relay for crescendo-email app (recommended providers: AWS SES, SendGrid, Mailgun)
crescendo.email.smtp.host=REPLACE_ME
crescendo.email.smtp.port=587
crescendo.email.smtp.username=REPLACE_ME
crescendo.email.smtp.password=REPLACE_ME

# Payment apps
# Razorpay and PayPal keys are normally user-owned connection credentials:
# - razorpay credentialSchema: keyId, keySecret
# - paypal credentialSchema: clientId, clientSecret, environment
# Admin/platform keys, if enabled, should be managed through platform key storage rather than hard-coded here.

# Optional provider key if you use Gemini connections
# Users still provide this per connection in production; keep server-level keys only for controlled internal use.
gemini.api.key=REPLACE_ME_IF_USED

# Optional provider key if you use Sarvam AI connections
# Leave empty if you do not want server-level fallback keys.
sarvam.api.key=REPLACE_ME_IF_USED

# Platform-managed API keys for public/free-tier APIs.
# These apps use AuthType.NONE — users don't need to create connections.
# Replace with your own keys for higher rate limits.
crescendo.platform.weather-api-key=REPLACE_ME
crescendo.platform.giphy-api-key=REPLACE_ME
crescendo.platform.nasa-api-key=REPLACE_ME

# Job Search provider API keys (platform-managed, leave blank to disable)
# SerpAPI — Google Jobs aggregator (100 free searches/month at https://serpapi.com)
crescendo.jobsearch.serpapi-key=REPLACE_ME
# Adzuna — Indian job market (free at https://developer.adzuna.com)
crescendo.jobsearch.adzuna-app-id=REPLACE_ME
crescendo.jobsearch.adzuna-api-key=REPLACE_ME
# Jooble — Global job aggregator (free at https://jooble.org/api/about)
crescendo.jobsearch.jooble-api-key=REPLACE_ME

# JWT expiration times in milliseconds
# 604800000 = 7 days (refresh token lifetime)
# 3600000   = 1 hour  (access token lifetime)
# WARNING: jwt.secret must be replaced with a strong secret and managed via environment variable in production
jwt.refresh.expiration=604800000
jwt.access.expiration=3600000
jwt.secret=REPLACE_ME_BASE64_KEY

# Frontend URL for OAuth2 redirects after login/failure
app.frontend.url=https://app.crescendo.run

# Allowed CORS origins
app.security.cors.allowed-origins=http://localhost:5173,https://app.crescendo.run

# Base URL used for open/click tracking links injected into outgoing HTML emails.
# Set this to the public URL where this backend is reachable (e.g. https://api.crescendo.run).
# Leave empty (default) to disable tracking injection in local development.
app.tracking.base-url=${app.backend-url}

# Redis Cache
spring.cache.type=redis
spring.data.redis.repositories.enabled=false
